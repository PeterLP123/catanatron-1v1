Bootstrap: docker
From: python:3.11-slim-bookworm

%labels
    Author Peter Prendergast
    Description Catanatron 1v1 runtime for UCL Myriad V100 and A100 nodes
    Python 3.11
    PyTorch 2.5.1-cu118

%files
    pyproject.toml /opt/catanatron-src/pyproject.toml
    README.md /opt/catanatron-src/README.md
    LICENSE /opt/catanatron-src/LICENSE
    catanatron /opt/catanatron-src/catanatron

%post
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        git \
        libgomp1
    rm -rf /var/lib/apt/lists/*

    python -m pip install --no-cache-dir --upgrade pip setuptools wheel
    python -m pip install --no-cache-dir \
        torch==2.5.1 \
        --index-url https://download.pytorch.org/whl/cu118
    cd /opt/catanatron-src
    python -m pip install --no-cache-dir ".[dev,gym,colonist]"

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export TOKENIZERS_PARALLELISM=false

%test
    python -c "import sys, torch; assert sys.version_info >= (3, 11); print(sys.version); print(torch.__version__)"

%runscript
    exec python "$@"
